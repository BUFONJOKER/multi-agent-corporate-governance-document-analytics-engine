# =========================================
# 🔹 GLOBAL / SYSTEM RULES (Any Folder)
# =========================================

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.tsbuildinfo

# Logs & Debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Secrets & Security (CRITICAL)
.env
.env*
.env.*
!.env.example
*.pem

# Media (Ignore only root level MP4s, or globally if preferred)
/*.mp4

# =========================================
# 🔹 PYTHON / BACKEND RULES (Any Folder)
# =========================================

# Virtual Environments
.venv/
env/
venv/
ENV/
.python-version

# Python Compiled Files (Global)
*.py[cod]
*$py.class

# Pycache Rule: Ignore everywhere, but explicitly allow if it's inside a frontend folder
**/__pycache__/
!frontend/**/__pycache__/

# Testing & Notebooks
.pytest_cache/
.ipynb_checkpoints/
coverage/
/coverage

# Build & Distribution
*.egg-info/
dist/
build/
/build
generated_images/
uploads/

# =========================================
# 🔹 JAVASCRIPT / FRONTEND RULES (Any Folder)
# =========================================

# Dependencies
node_modules/
/node_modules

# Next.js / Build Artifacts
.next/
/.next/
out/
/out/
next-env.d.ts

# Package Managers (Yarn/PNP/Pnpm)
.pnp
.pnp.js
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================================
# 🔹 DEPLOYMENT & CLOUD
# =========================================

.vercel

# typescript
*.tsbuildinfo
next-env.d.ts